# ============================================================
# CHRONOS FÚTBOL — .gitignore (Fase 0 + Fase 1)
# ============================================================

# DEPENDENCIAS
node_modules/
**/node_modules/
functions/node_modules/

# FIREBASE
.firebase/
.firebase-*
firebase-debug.log*
firestore-debug.log*

# PII Y SECRETOS (JAMÁS EN EL REPO)
usuarios_temp.json
usuarios_temp*.json
*.BACKUP
*.REVIEW
*.bak
*.backup
serviceAccountKey.json
service-account-key.json
firebase-adminsdk-*.json
*secret*
.env
.env.*

# ARTIFACTOS DE DESARROLLO
*.diff
*.patch
test_fixes_*.js
*.log

# BUILD / DIST
dist/
build/
.cache/
.vite/

# EDITORES / IDE
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# TESTING / COBERTURA
coverage/
.nyc_output/
test-results/
junit.xml
# HERRAMIENTAS TEMPORALES DE VALIDACION DE REGLAS (no forma parte del build)
rules_test/
_*.txt

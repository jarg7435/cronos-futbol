rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Minimal reproduction of the transitionalRead() helper from
    // firestore.rules to test whether `request.auth.time` exists.
    function isAuth() { return request.auth != null; }
    function hasClaims() {
      return isAuth() &&
             request.auth.token.role != null &&
             request.auth.token.clubId != null;
    }
    function transitionalRead(clubId) {
      return isAuth() && !hasClaims() && clubId != null
             && (request.time - request.auth.time) < duration.value(5, 'm');
    }

    // A version using request.auth.token.auth_time (int seconds) instead.
    function transitionalReadAuthTime(clubId) {
      return isAuth() && !hasClaims() && clubId != null
             && request.auth.token.auth_time != null
             && (request.time.toMillis() - request.auth.token.auth_time * 1000) < 300000;
    }

    match /probe_authtime/{id} {
      allow read: if transitionalRead(resource.data.clubId);
    }
    match /probe_authtime2/{id} {
      allow read: if transitionalReadAuthTime(resource.data.clubId);
    }
  }
}

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ============================================================
    // FUNCIONES HELPER
    // ============================================================

    function isAuth() {
      return request.auth != null;
    }

    // FIX: isSuperAdminEmail() verifica contra cronos_config/superadmins
    // en lugar de hardcodear un email. Esto evita:
    //   1. Typos en el email hardcodeado (jarg7435 vs jarc7435)
    //   2. Que cambios de email del SA requieran redeploy de reglas
    //   3. Que múltiples SAs no sean reconocidos
    function isSuperAdminEmail() {
      return isAuth() &&
             get(/databases/$(database)/documents/cronos_config/superadmins).data.emails
               .has(request.auth.token.email);
    }

    function isSuperAdmin() {
      return isAuth() &&
             (request.auth.token.role == 'superadmin' ||
              isSuperAdminEmail());
    }

    function isClubAdmin(clubId) {
      return isAuth() &&
             request.auth.token.role == 'club_admin' &&
             request.auth.token.clubId == clubId;
    }

    function isIndividualAdmin(clubId) {
      return isAuth() &&
             (request.auth.token.role == 'individual_admin' ||
              request.auth.token.role == 'individual' ||
              request.auth.token.role == 'admin_individual') &&
             request.auth.token.clubId == clubId;
    }

    function isIndividualRole() {
      return isAuth() &&
             (request.auth.token.role == 'individual' ||
              request.auth.token.role == 'individual_admin' ||
              request.auth.token.role == 'admin_individual');
    }

    function sameClub(clubId) {
      return isClubAdmin(clubId) || isIndividualAdmin(clubId);
    }

    function hasClaims() {
      return isAuth() &&
             request.auth.token.role != null &&
             request.auth.token.clubId != null;
    }

    // FIX: transitionalRead ahora tiene límite de tiempo de 5 minutos.
    // Antes: sin límite = backdoor permanente si los claims nunca se asignaban.
    // Ahora: solo aplica si el usuario se registró en los últimos 5 minutos.
    function transitionalRead(clubId) {
      return isAuth() && !hasClaims() && clubId != null
             && (request.time - request.auth.time) < duration.value(5, 'm');
    }

    function isIndividualEntity(resourceData) {
      return resourceData.type == 'individual';
    }

    // Mismo club por campo del documento
    function sameClubAsDoc(docClubId) {
      return isAuth() && request.auth.token.clubId == docClubId;
    }

    // FIX (club_admin sin claim): permite que el administrador real de un club
    // —según el documento del club (clubs/{clubId}.adminUid)— lea los docs de
    // 'users' de su club aunque su TOKEN aún no tenga el custom claim 'clubId'
    // (los claims se asignan vía setCustomClaims; este fallback cubre a los
    // club_admin ya aprobados antes de que se asignaran claims). Solo concede
    // acceso si el uid coincide con el adminUid registrado en el club, así que
    // no amplía la superficie de seguridad más allá del verdadero admin.
    function isClubAdminOf(docClubId) {
      return isAuth() && docClubId != null
             && exists(/databases/$(database)/documents/clubs/$(docClubId))
             && (
                  get(/databases/$(database)/documents/clubs/$(docClubId)).data.adminUid == request.auth.uid
                  || get(/databases/$(database)/documents/clubs/$(docClubId)).data.adminEmail == request.auth.token.email
                );
    }

    // El usuario es el propietario del enlace padre→jugador
    function isLinkOwner() {
      return isAuth() && request.auth.uid == resource.data.parentUid;
    }

    // El usuario tiene acceso al club de este enlace
    function isLinkClubMember() {
      return isAuth() && (
        sameClub(resource.data.clubId) ||
        sameClubAsDoc(resource.data.clubId)
      );
    }

    function isValidPlayerData(data) {
      return data.keys().hasOnly([
        'pseudonym', 'number', 'position', 'isStarting',
        'teamId', 'clubId', 'matchId', 'updatedAt', 'isActive',
        'name', 'surname', 'createdAt'
      ]);
    }

    // ============================================================
    // COLECCIÓN: users
    // SEC-011: Prevent self-role escalation
    // ============================================================
    match /users/{userId} {
      allow read: if isAuth() && (
        isSuperAdmin() ||
        request.auth.uid == userId ||
        sameClubAsDoc(resource.data.clubId) ||
        isClubAdminOf(resource.data.clubId) ||
        transitionalRead(resource.data.clubId)
      );
      allow create: if isAuth() && (
        request.auth.uid == userId ||
        isSuperAdmin()
      );
      // FIX (multi-rol): se permite que el usuario actualice su propio
      // 'allRoles' para AÑADIR roles PENDIENTES (necesario para el flujo
      // "añadir rol a cuenta existente"). La escalada real se sigue
      // bloqueando porque los campos de RAÍZ que controlan el acceso
      // efectivo ('role', 'isAuthorized', 'status', 'clubId', 'clubName',
      // 'authorizedAt', 'authorizedBy', 'blockedAt') permanecen prohibidos
      // para el propio usuario. El gate de entrada (auth.js) NO confía en
      // 'allRoles[].isAuthorized' del cliente: solo activa un rol cuando la
      // RAÍZ 'isAuthorized' es true (escrita por el SA vía Admin SDK).
      allow update: if isSuperAdmin() ||
        (isAuth() && request.auth.uid == userId
          && !request.resource.data.diff(resource.data).affectedKeys()
              .hasAny(['role', 'isAuthorized', 'status', 'clubId', 'clubName', 'authorizedAt', 'authorizedBy', 'blockedAt']));
      allow delete: if isSuperAdmin();
    }

    // ============================================================
    // COLECCIÓN: clubs
    // SEC-008: Require authentication for read
    // ============================================================
    match /clubs/{clubId} {
      allow read: if isAuth();
      allow create: if isSuperAdmin();
      allow update: if isSuperAdmin() ||
                       isClubAdmin(clubId) ||
                       (isIndividualAdmin(clubId) &&
                        isIndividualEntity(resource.data));
      allow delete: if isSuperAdmin();
    }

    // ============================================================
    // COLECCIÓN: clubs_public
    // Espejo PÚBLICO de clubs con solo 3 campos: name, type, status.
    // Permite que el formulario de registro liste los clubes/entes
    // disponibles SIN autenticación, manteniendo 'clubs' protegida.
    // La escritura SOLO la realiza la Cloud Function syncClubPublic
    // (Admin SDK), por eso aquí no se permite write desde el cliente.
    // ============================================================
    match /clubs_public/{clubId} {
      allow read: if true;
      allow write: if false;
    }

    // ============================================================
    // COLECCIÓN: individuals
    // FIX: antes era "if isAuth()" — cualquier usuario autenticado
    // podía leer los entes individuales de otros clubs.
    // ============================================================
    match /individuals/{entityId} {
      allow read: if isAuth() && (
        isSuperAdmin() ||
        sameClubAsDoc(resource.data.clubId) ||
        transitionalRead(resource.data.clubId)
      );
      allow create: if isSuperAdmin();
      allow update: if isSuperAdmin() ||
                       (isAuth() &&
                        resource.data.email == request.auth.token.email);
      allow delete: if isSuperAdmin();
    }

    // ============================================================
    // COLECCIÓN: platform_requests
    // ============================================================
    match /platform_requests/{reqId} {
      allow read: if isSuperAdmin() ||
                     (isAuth() && (
                       sameClubAsDoc(resource.data.clubId) ||
                       request.auth.uid == resource.data.requestedBy ||
                       request.auth.uid == resource.data.userId ||
                       request.auth.token.clubId == resource.data.individualOwnerId
                     ));
      allow create: if isAuth();
      allow update: if isSuperAdmin() ||
                       (isAuth() && sameClubAsDoc(resource.data.clubId));
      allow delete: if isSuperAdmin();
    }

    // ============================================================
    // COLECCIÓN: matches
    // FIX: antes era "allow read: if isAuth()"
    // ============================================================
    match /matches/{matchId} {
      allow read: if isAuth() && (
        isSuperAdmin() ||
        sameClub(resource.data.clubId) ||
        sameClubAsDoc(resource.data.clubId) ||
        transitionalRead(resource.data.clubId)
      );
      allow create: if isAuth() && (
        isSuperAdmin() ||
        sameClub(request.resource.data.clubId) ||
        transitionalRead(request.resource.data.clubId)
      );
      allow update: if isAuth() && (
        isSuperAdmin() ||
        sameClub(resource.data.clubId) ||
        transitionalRead(resource.data.clubId)
      );
      allow delete: if isSuperAdmin();
    }

    // ============================================================
    // COLECCIÓN: players (jugadores — pueden ser MENORES)
    // ============================================================
    match /players/{playerId} {
      allow read: if isAuth() && (
        isSuperAdmin() ||
        sameClub(resource.data.clubId) ||
        sameClubAsDoc(resource.data.clubId) ||
        transitionalRead(resource.data.clubId)
      );
      allow create: if isAuth() && (
        isSuperAdmin() ||
        sameClub(request.resource.data.clubId) ||
        transitionalRead(request.resource.data.clubId)
      ) && isValidPlayerData(request.resource.data);
      allow update: if isAuth() && (
        isSuperAdmin() ||
        sameClub(resource.data.clubId) ||
        transitionalRead(resource.data.clubId)
      ) && isValidPlayerData(request.resource.data);
      allow delete: if isSuperAdmin();
    }

    // ============================================================
    // COLECCIÓN: teams
    // ============================================================
    match /teams/{teamId} {
      allow read: if isAuth() && (
        isSuperAdmin() ||
        sameClub(resource.data.clubId) ||
        sameClubAsDoc(resource.data.clubId) ||
        transitionalRead(resource.data.clubId)
      );
      allow create: if isAuth() && (
        isSuperAdmin() ||
        sameClub(request.resource.data.clubId) ||
        transitionalRead(request.resource.data.clubId)
      );
      allow update: if isAuth() && (
        isSuperAdmin() ||
        sameClub(resource.data.clubId) ||
        transitionalRead(resource.data.clubId)
      );
      allow delete: if isSuperAdmin();
    }

    // ============================================================
    // COLECCIÓN: formations
    // ============================================================
    match /formations/{formationId} {
      allow read: if isAuth() && (
        isSuperAdmin() ||
        sameClub(resource.data.clubId) ||
        sameClubAsDoc(resource.data.clubId) ||
        transitionalRead(resource.data.clubId)
      );
      allow create: if isAuth() && (
        isSuperAdmin() ||
        sameClub(request.resource.data.clubId) ||
        transitionalRead(request.resource.data.clubId)
      );
      allow update: if isAuth() && (
        isSuperAdmin() ||
        sameClub(resource.data.clubId) ||
        transitionalRead(resource.data.clubId)
      );
      allow delete: if isSuperAdmin();
    }

    // ============================================================
    // COLECCIÓN: substitutions
    // ============================================================
    match /substitutions/{subId} {
      allow read: if isAuth() && (
        isSuperAdmin() ||
        sameClub(resource.data.clubId) ||
        sameClubAsDoc(resource.data.clubId) ||
        transitionalRead(resource.data.clubId)
      );
      allow create: if isAuth() && (
        isSuperAdmin() ||
        sameClub(request.resource.data.clubId) ||
        transitionalRead(request.resource.data.clubId)
      );
      allow update: if isAuth() && (
        isSuperAdmin() ||
        sameClub(resource.data.clubId) ||
        transitionalRead(resource.data.clubId)
      );
      allow delete: if isSuperAdmin();
    }

    // ============================================================
    // COLECCIÓN: events
    // ============================================================
    match /events/{eventId} {
      allow read: if isAuth() && (
        isSuperAdmin() ||
        sameClub(resource.data.clubId) ||
        sameClubAsDoc(resource.data.clubId) ||
        transitionalRead(resource.data.clubId)
      );
      allow create: if isAuth() && (
        isSuperAdmin() ||
        sameClub(request.resource.data.clubId) ||
        transitionalRead(request.resource.data.clubId)
      );
      allow update: if isAuth() && (
        isSuperAdmin() ||
        sameClub(resource.data.clubId) ||
        transitionalRead(resource.data.clubId)
      );
      allow delete: if isSuperAdmin();
    }

    // ============================================================
    // COLECCIÓN: cronos_messages
    // SEC-005: Restrict create
    // ============================================================
    match /cronos_messages/{threadId} {
      allow read: if isAuth() && (
        isSuperAdmin() ||
        sameClubAsDoc(resource.data.clubId) ||
        request.auth.uid in resource.data.participants ||
        transitionalRead(resource.data.clubId)
      );
      allow create: if isAuth() && (
        isSuperAdmin() ||
        sameClub(request.resource.data.clubId) ||
        request.auth.uid in request.resource.data.participants
      );
      allow update: if isAuth() && (
        isSuperAdmin() ||
        sameClubAsDoc(resource.data.clubId) ||
        request.auth.uid in resource.data.participants
      );
      allow delete: if isAuth() &&
                    (request.auth.uid in resource.data.participants || isSuperAdmin());
    }

    // ============================================================
    // COLECCIÓN: cronos_notifications
    // SEC-004/SEC-015: Restrict create
    // ============================================================
    match /cronos_notifications/{notifId} {
      allow read: if isAuth() && (
        isSuperAdmin() ||
        request.auth.uid == resource.data.userId ||
        sameClubAsDoc(resource.data.clubId)
      );
      allow create: if isAuth() && (
        isSuperAdmin() ||
        sameClubAsDoc(request.resource.data.clubId) ||
        request.auth.uid == request.resource.data.coachUid ||
        request.auth.uid == request.resource.data.userId
      );
      allow update: if isAuth() && (
        isSuperAdmin() ||
        request.auth.uid == resource.data.userId
      );
      allow delete: if isAuth() && (
        isSuperAdmin() ||
        request.auth.uid == resource.data.userId
      );
    }

    // ============================================================
    // COLECCIÓN: cronos_player_reports
    // SEC-013: Validate club on create
    // ============================================================
    match /cronos_player_reports/{reportId} {
      allow read: if isAuth() && (
        isSuperAdmin() ||
        sameClubAsDoc(resource.data.clubId) ||
        request.auth.uid == resource.data.coachUid ||
        request.auth.uid == resource.data.parentUid ||
        transitionalRead(resource.data.clubId)
      );
      allow create: if isAuth() && (
        isSuperAdmin() ||
        sameClub(request.resource.data.clubId) ||
        request.auth.uid == request.resource.data.coachUid
      );
      allow update: if isAuth() && (
        isSuperAdmin() ||
        sameClubAsDoc(resource.data.clubId) ||
        request.auth.uid == resource.data.coachUid
      );
      allow delete: if isAuth() && (
        isSuperAdmin() ||
        sameClubAsDoc(resource.data.clubId) ||
        request.auth.uid == resource.data.coachUid
      );
    }

    // ============================================================
    // COLECCIÓN: cronos_player_links
    // FIX CRÍTICO: antes era "allow read, write: if isAuth()"
    // ============================================================
    match /cronos_player_links/{linkId} {
      allow read: if isAuth() && (
        isSuperAdmin() ||
        isLinkOwner() ||
        isLinkClubMember() ||
        transitionalRead(resource.data.clubId)
      );
      allow create: if isAuth() && (
        isSuperAdmin() ||
        sameClub(request.resource.data.clubId) ||
        sameClubAsDoc(request.resource.data.clubId)
      );
      allow update: if isAuth() && (
        isSuperAdmin() ||
        isLinkOwner() ||
        isLinkClubMember()
      );
      allow delete: if isAuth() && (
        isSuperAdmin() ||
        isLinkClubMember()
      );
    }

    // ============================================================
    // COLECCIÓN: deletion_requests
    // ============================================================
    match /deletion_requests/{reqId} {
      allow read: if isAuth() && (
        isSuperAdmin() ||
        request.auth.uid == resource.data.userId
      );
      allow create: if isAuth();
      allow update: if isSuperAdmin();
      allow delete: if isSuperAdmin();
    }

    // ============================================================
    // COLECCIÓN: auth_deletion_failures
    // Cola de revisión: se escribe cuando deleteAuthUser (Cloud
    // Function) falla durante un borrado total. El documento incluye
    // 'requestedBy' = uid del admin que solicitó el borrado, así que
    // el create exige que coincida con el solicitante autenticado:
    // un usuario solo puede registrar fallos de SUS PROPIAS acciones
    // (no puede falsificar la identidad del solicitante ni inundar la
    // cola en nombre de otro). Contiene PII (email del usuario
    // borrado), por eso SOLO el SuperAdmin puede leer la cola.
    // Documentos inmutables: sin update; el SA puede purgar (delete)
    // tras resolver el fallo.
    // FIX: antes NO existía regla → caía en el catch-all (deny) y los
    // registros de fallo se perdían silenciosamente (el write quedaba
    // tragado por el try/catch del cliente).
    // ============================================================
    match /auth_deletion_failures/{failId} {
      allow read: if isSuperAdmin();
      allow create: if isAuth() &&
                       request.resource.data.requestedBy == request.auth.uid;
      allow update: if false;
      allow delete: if isSuperAdmin();
    }

    // ============================================================
    // COLECCIÓN: live_matches
    // SEC-014: Restrict writes to same-club
    // ============================================================
    match /live_matches/{matchId} {
      allow read: if true;
      allow create: if isAuth() && (isSuperAdmin() || sameClub(request.resource.data.clubId));
      allow update: if isAuth() && (isSuperAdmin() || sameClub(resource.data.clubId));
      allow delete: if isAuth() && (isSuperAdmin() || sameClub(resource.data.clubId));
    }

    // ============================================================
    // COLECCIÓN: users/{uid}/cronos_data
    // ============================================================
    match /users/{userId}/cronos_data/{docId} {
      allow read, write: if isAuth() && request.auth.uid == userId;
    }

    // ============================================================
    // COLECCIÓN: offline_events
    // SEC-007: Validate userUid on create
    // ============================================================
    match /offline_events/{eventId} {
      allow read: if isAuth() && resource.data.userUid == request.auth.uid;
      allow create: if isAuth() && request.resource.data.userUid == request.auth.uid;
      allow update, delete: if isAuth() && resource.data.userUid == request.auth.uid;
    }

    // ============================================================
    // COLECCIÓN: config / cronos_config
    // ============================================================
    match /config/{configId} {
      allow read: if isAuth();
      allow write: if isSuperAdmin();
    }

    match /cronos_config/{configId} {
      allow read: if isAuth();
      allow write: if isSuperAdmin();
    }

    // SEC-012: Restrict superadmins doc to superadmin-only
    match /cronos_config/superadmins {
      allow read: if isSuperAdmin();
      allow write: if isSuperAdmin();
    }

    // ============================================================
    // COLECCIÓN: pseudonym_map
    // ============================================================
    match /pseudonym_map/{mapId} {
      allow read: if isAuth() && (
        isSuperAdmin() ||
        sameClub(resource.data.clubId) ||
        transitionalRead(resource.data.clubId)
      );
      allow write: if false;
    }

    // ============================================================
    // COLECCIÓN: audit_logs / error_logs
    // ============================================================
    match /audit_logs/{logId} {
      allow read: if isSuperAdmin();
      allow write: if false;
    }

    match /error_logs/{logId} {
      allow read: if isSuperAdmin();
      allow write: if false;
    }

    // ============================================================
    // COLECCIÓN: notifications
    // ============================================================
    match /notifications/{notifId} {
      allow read: if isAuth() && (
        isSuperAdmin() ||
        request.auth.uid == resource.data.userId ||
        sameClubAsDoc(resource.data.clubId)
      );
      allow create: if isAuth();
      allow update: if isAuth() && (
        isSuperAdmin() ||
        request.auth.uid == resource.data.userId
      );
      allow delete: if isSuperAdmin();
    }

    // ============================================================
    // COLECCIÓN: slot_requests
    // ============================================================
    match /slot_requests/{reqId} {
      allow read: if isAuth() && (
        isSuperAdmin() ||
        request.auth.uid == resource.data.userId ||
        sameClubAsDoc(resource.data.clubId)
      );
      allow create: if isAuth();
      allow update: if isAuth() && (
        isSuperAdmin() ||
        sameClubAsDoc(resource.data.clubId)
      );
      allow delete: if isSuperAdmin();
    }

    // ============================================================
    // COLECCIÓN: succession_requests
    // ============================================================
    match /succession_requests/{reqId} {
      allow read: if isSuperAdmin();
      allow create: if isAuth() &&
                       request.auth.token.role == 'club_admin' &&
                       request.resource.data.outgoingAdminUid == request.auth.uid;
      allow update: if isSuperAdmin();
      allow delete: if isSuperAdmin();
    }

    // ============================================================
    // COLECCIONES DE FACTURACIÓN
    // ============================================================
    match /billing_plans/{planId} {
      allow read: if isAuth();
      allow write: if isSuperAdmin();
    }

    match /billing_subscriptions/{subId} {
      allow read: if isSuperAdmin() ||
                     (isAuth() && resource.data.entityId == request.auth.token.clubId) ||
                     (isAuth() && resource.data.entityId == request.auth.uid);
      allow create: if isSuperAdmin();
      allow update: if isSuperAdmin();
      allow delete: if isSuperAdmin();
    }

    match /billing_invoices/{invId} {
      allow read: if isSuperAdmin() ||
                     (isAuth() && resource.data.entityId == request.auth.token.clubId) ||
                     (isAuth() && resource.data.entityId == request.auth.uid);
      allow create: if isSuperAdmin();
      allow update: if isSuperAdmin();
      allow delete: if isSuperAdmin();
    }

    // ============================================================
    // COLECCIÓN: trainingPlans/{clubId}  (documento raíz)
    // SPRINT 4 — BLOQUE C: Planes de entrenamiento.
    // El documento raíz puede no existir; las semanas viven en la
    // subcolección 'weeks'. Se permite read defensivamente; el write
    // del raíz se bloquea (los datos viven en la subcolección).
    // ============================================================
    match /trainingPlans/{clubId} {
      allow read: if isAuth() && (
        isSuperAdmin() ||
        sameClub(clubId)
      );
      allow write: if false;
    }

    // ============================================================
    // COLECCIÓN: trainingPlans/{clubId}/weeks/{weekKey}
    // Documentos: { ...weekData, lastModified, createdBy }
    // (NO contienen campo clubId propio → se valida contra la RUTA)
    // ============================================================
    match /trainingPlans/{clubId}/weeks/{weekKey} {
      allow read: if isAuth() && (
        isSuperAdmin() ||
        sameClub(clubId) ||
        sameClubAsDoc(clubId) ||
        transitionalRead(clubId)
      );
      allow create, update: if isAuth() && (
        isSuperAdmin() ||
        sameClub(clubId) ||
        transitionalRead(clubId)
      );
      allow delete: if isAuth() && (isSuperAdmin() || sameClub(clubId));
    }

    // ============================================================
    // CATCH-ALL — bloquear TODO lo no definido explícitamente
    // FIX CRÍTICO: antes era "allow read: if isAuth()"
    // ============================================================
    match /{document=**} {
      allow read, write: if false;
    }
  }
}

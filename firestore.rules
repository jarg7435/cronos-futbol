rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ═══════════════════════════════════════════════════════════════════
    // HELPERS
    // ═══════════════════════════════════════════════════════════════════
    function isAuthenticated() {
      return request.auth != null;
    }
    function isSuperAdmin() {
      return isAuthenticated() &&
             request.auth.token.email == 'jarg7435@gmail.com';
    }

    // ═══════════════════════════════════════════════════════════════════
    // clubs — Solo SA escribe; lectura para todos (incluido registro)
    // ═══════════════════════════════════════════════════════════════════
    match /clubs/{clubId} {
      allow read: if true;
      allow create, update, delete: if isSuperAdmin();
    }

    // ═══════════════════════════════════════════════════════════════════
    // users — Lectura para autenticados; escritura según reglas de rol
    // ═══════════════════════════════════════════════════════════════════
    match /users/{userId} {
      // Lectura: cualquier usuario autenticado
      allow read: if isAuthenticated();

      // Creación: el propio usuario creando su propio documento al registrarse
      allow create: if isAuthenticated()
                    && request.auth.uid == userId;

      // Actualización: el propio usuario o SA
      allow update: if isAuthenticated()
                    && (request.auth.uid == userId || isSuperAdmin());

      // Eliminación: solo SA o el propio usuario
      allow delete: if isAuthenticated()
                    && (request.auth.uid == userId || isSuperAdmin());
    }

    // ═══════════════════════════════════════════════════════════════════
    // platform_requests — Solicitudes entre club admin y SA
    // ═══════════════════════════════════════════════════════════════════
    match /platform_requests/{requestId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isAuthenticated();
      allow delete: if isAuthenticated();
    }

    // ═══════════════════════════════════════════════════════════════════
    // cronos_player_links — Links para padres
    // ═══════════════════════════════════════════════════════════════════
    match /cronos_player_links/{linkId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isAuthenticated();
      allow delete: if isAuthenticated();
    }

    // ═══════════════════════════════════════════════════════════════════
    // Global defaults — denegar todo lo que no coincide
    // ═══════════════════════════════════════════════════════════════════
    match /{document=**} {
      allow read, write: if false;
    }
  }
}

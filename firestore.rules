rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ============================================================
    // FUNCIONES HELPER
    // ============================================================

    function isAuth() {
      return request.auth != null;
    }

    // FIX: isSuperAdminEmail() verifica contra cronos_config/superadmins
    // en lugar de hardcodear un email. Esto evita:
    //   1. Typos en el email hardcodeado (jarg7435 vs jarc7435)
    //   2. Que cambios de email del SA requieran redeploy de reglas
    //   3. Que múltiples SAs no sean reconocidos
    function isSuperAdminEmail() {
      return isAuth() &&
             get(/databases/$(database)/documents/cronos_config/superadmins).data.emails
               .has(request.auth.token.email);
    }

    function isSuperAdmin() {
      return isAuth() &&
             (request.auth.token.role == 'superadmin' ||
              isSuperAdminEmail());
    }

    function isClubAdmin(clubId) {
      return isAuth() &&
             request.auth.token.role == 'club_admin' &&
             request.auth.token.clubId == clubId;
    }

    function isIndividualAdmin(clubId) {
      return isAuth() &&
             (request.auth.token.role == 'individual_admin' ||
              request.auth.token.role == 'individual' ||
              request.auth.token.role == 'admin_individual') &&
             request.auth.token.clubId == clubId;
    }

    function isIndividualRole() {
      return isAuth() &&
             (request.auth.token.role == 'individual' ||
              request.auth.token.role == 'individual_admin' ||
              request.auth.token.role == 'admin_individual');
    }

    function sameClub(clubId) {
      return isClubAdmin(clubId) || isIndividualAdmin(clubId);
    }

    function hasClaims() {
      return isAuth() &&
             request.auth.token.role != null &&
             request.auth.token.clubId != null;
    }

    // FIX: transitionalRead ahora tiene límite de tiempo de 5 minutos.
    // Antes: sin límite = backdoor permanente si los claims nunca se asignaban.
    // Ahora: solo aplica si el usuario se registró en los últimos 5 minutos.
    // El campo auth.time es epoch segundos (string en token).
    function transitionalRead(clubId) {
      return isAuth() && !hasClaims() && clubId != null
             && (request.time - request.auth.time) < duration.value(5, 'm');
    }

    function isIndividualEntity(resourceData) {
      return resourceData.type == 'individual';
    }

    // Mismo club por campo del documento (para usuarios sin custom claims propagados)
    function sameClubAsDoc(docClubId) {
      return isAuth() && request.auth.token.clubId == docClubId;
    }

    // El usuario es el propietario del enlace padre→jugador
    function isLinkOwner() {
      return isAuth() && request.auth.uid == resource.data.parentUid;
    }

    // El usuario tiene acceso al club de este enlace (coach/admin del mismo club)
    function isLinkClubMember() {
      return isAuth() && (
        sameClub(resource.data.clubId) ||
        sameClubAsDoc(resource.data.clubId)
      );
    }

    function isValidPlayerData(data) {
      return data.keys().hasOnly([
        'pseudonym', 'number', 'position', 'isStarting',
        'teamId', 'clubId', 'matchId', 'updatedAt', 'isActive',
        'name', 'surname', 'createdAt'
      ]);
    }

    // ============================================================
    // COLECCIÓN: users
    // Cada usuario solo lee su propio documento o el de su mismo club.
    // ============================================================
    match /users/{userId} {
      allow read: if isAuth() && (
        isSuperAdmin() ||
        request.auth.uid == userId ||
        sameClubAsDoc(resource.data.clubId) ||
        transitionalRead(resource.data.clubId)
      );
      allow create: if isAuth() && (
        request.auth.uid == userId ||
        isSuperAdmin()
      );
      allow update: if isSuperAdmin() ||
                       (isAuth() && request.auth.uid == userId);
      allow delete: if isSuperAdmin();
    }

    // ============================================================
    // COLECCIÓN: clubs
    // Lectura pública necesaria para el formulario de registro.
    // ============================================================
    match /clubs/{clubId} {
      allow read: if true;
      allow create: if isSuperAdmin();
      allow update: if isSuperAdmin() ||
                       isClubAdmin(clubId) ||
                       (isIndividualAdmin(clubId) &&
                        isIndividualEntity(resource.data));
      allow delete: if isSuperAdmin();
    }

    // ============================================================
    // COLECCIÓN: individuals
    // FIX: antes era "if isAuth()" — cualquier usuario autenticado
    // podía leer los entes individuales de otros clubs.
    // Ahora: solo SA, miembros del mismo ente o transitional.
    // ============================================================
    match /individuals/{entityId} {
      allow read: if isAuth() && (
        isSuperAdmin() ||
        sameClubAsDoc(resource.data.clubId) ||
        transitionalRead(resource.data.clubId)
      );
      allow create: if isSuperAdmin();
      allow update: if isSuperAdmin() ||
                       (isAuth() &&
                        resource.data.email == request.auth.token.email);
      allow delete: if isSuperAdmin();
    }

    // ============================================================
    // COLECCIÓN: platform_requests
    // Solo SA y el admin del club/entidad implicada pueden leer.
    // Cualquier autenticado puede crear (para registros).
    // Solo SA puede actualizar (aprobar/rechazar) o eliminar.
    // ============================================================
    match /platform_requests/{reqId} {
      allow read: if isSuperAdmin() ||
                     (isAuth() && (
                       sameClubAsDoc(resource.data.clubId) ||
                       request.auth.uid == resource.data.requestedBy ||
                       request.auth.uid == resource.data.userId ||
                       request.auth.token.clubId == resource.data.individualOwnerId
                     ));
      allow create: if isAuth();
      allow update: if isSuperAdmin() ||
                       (isAuth() && sameClubAsDoc(resource.data.clubId));
      allow delete: if isSuperAdmin();
    }

    // ============================================================
    // COLECCIÓN: matches
    // FIX: antes era "allow read: if isAuth()" — cualquier usuario
    // autenticado veía los partidos de cualquier club.
    // Ahora: restringido al club propietario.
    // ============================================================
    match /matches/{matchId} {
      allow read: if isAuth() && (
        isSuperAdmin() ||
        sameClub(resource.data.clubId) ||
        sameClubAsDoc(resource.data.clubId) ||
        transitionalRead(resource.data.clubId)
      );
      allow create: if isAuth() && (
        isSuperAdmin() ||
        sameClub(request.resource.data.clubId) ||
        transitionalRead(request.resource.data.clubId)
      );
      allow update: if isAuth() && (
        isSuperAdmin() ||
        sameClub(resource.data.clubId) ||
        transitionalRead(resource.data.clubId)
      );
      allow delete: if isSuperAdmin();
    }

    // ============================================================
    // COLECCIÓN: players (jugadores — pueden ser MENORES)
    // Solo el club propietario puede leer.
    // ============================================================
    match /players/{playerId} {
      allow read: if isAuth() && (
        isSuperAdmin() ||
        sameClub(resource.data.clubId) ||
        sameClubAsDoc(resource.data.clubId) ||
        transitionalRead(resource.data.clubId)
      );
      allow create: if isAuth() && (
        isSuperAdmin() ||
        sameClub(request.resource.data.clubId) ||
        transitionalRead(request.resource.data.clubId)
      ) && isValidPlayerData(request.resource.data);
      allow update: if isAuth() && (
        isSuperAdmin() ||
        sameClub(resource.data.clubId) ||
        transitionalRead(resource.data.clubId)
      ) && isValidPlayerData(request.resource.data);
      allow delete: if isSuperAdmin();
    }

    // ============================================================
    // COLECCIÓN: teams
    // FIX: antes era "allow read: if isAuth()" — cualquier usuario
    // autenticado veía los equipos de cualquier club.
    // ============================================================
    match /teams/{teamId} {
      allow read: if isAuth() && (
        isSuperAdmin() ||
        sameClub(resource.data.clubId) ||
        sameClubAsDoc(resource.data.clubId) ||
        transitionalRead(resource.data.clubId)
      );
      allow create: if isAuth() && (
        isSuperAdmin() ||
        sameClub(request.resource.data.clubId) ||
        transitionalRead(request.resource.data.clubId)
      );
      allow update: if isAuth() && (
        isSuperAdmin() ||
        sameClub(resource.data.clubId) ||
        transitionalRead(resource.data.clubId)
      );
      allow delete: if isSuperAdmin();
    }

    // ============================================================
    // COLECCIÓN: formations
    // FIX: antes era "allow read: if isAuth()"
    // ============================================================
    match /formations/{formationId} {
      allow read: if isAuth() && (
        isSuperAdmin() ||
        sameClub(resource.data.clubId) ||
        sameClubAsDoc(resource.data.clubId) ||
        transitionalRead(resource.data.clubId)
      );
      allow create: if isAuth() && (
        isSuperAdmin() ||
        sameClub(request.resource.data.clubId) ||
        transitionalRead(request.resource.data.clubId)
      );
      allow update: if isAuth() && (
        isSuperAdmin() ||
        sameClub(resource.data.clubId) ||
        transitionalRead(resource.data.clubId)
      );
      allow delete: if isSuperAdmin();
    }

    // ============================================================
    // COLECCIÓN: substitutions
    // FIX: antes era "allow read: if isAuth()"
    // ============================================================
    match /substitutions/{subId} {
      allow read: if isAuth() && (
        isSuperAdmin() ||
        sameClub(resource.data.clubId) ||
        sameClubAsDoc(resource.data.clubId) ||
        transitionalRead(resource.data.clubId)
      );
      allow create: if isAuth() && (
        isSuperAdmin() ||
        sameClub(request.resource.data.clubId) ||
        transitionalRead(request.resource.data.clubId)
      );
      allow update: if isAuth() && (
        isSuperAdmin() ||
        sameClub(resource.data.clubId) ||
        transitionalRead(resource.data.clubId)
      );
      allow delete: if isSuperAdmin();
    }

    // ============================================================
    // COLECCIÓN: events
    // FIX: antes era "allow read: if isAuth()"
    // ============================================================
    match /events/{eventId} {
      allow read: if isAuth() && (
        isSuperAdmin() ||
        sameClub(resource.data.clubId) ||
        sameClubAsDoc(resource.data.clubId) ||
        transitionalRead(resource.data.clubId)
      );
      allow create: if isAuth() && (
        isSuperAdmin() ||
        sameClub(request.resource.data.clubId) ||
        transitionalRead(request.resource.data.clubId)
      );
      allow update: if isAuth() && (
        isSuperAdmin() ||
        sameClub(resource.data.clubId) ||
        transitionalRead(resource.data.clubId)
      );
      allow delete: if isSuperAdmin();
    }

    // ============================================================
    // COLECCIÓN: cronos_messages
    // Solo participantes del hilo o SA pueden leer y escribir.
    // ============================================================
    match /cronos_messages/{threadId} {
      allow read: if isAuth() && (
        isSuperAdmin() ||
        sameClubAsDoc(resource.data.clubId) ||
        request.auth.uid in resource.data.participants ||
        transitionalRead(resource.data.clubId)
      );
      allow create: if isAuth();
      allow update: if isAuth() && (
        isSuperAdmin() ||
        sameClubAsDoc(resource.data.clubId) ||
        request.auth.uid in resource.data.participants
      );
      allow delete: if isAuth() &&
                    (request.auth.uid in resource.data.participants || isSuperAdmin());
    }

    // ============================================================
    // COLECCIÓN: cronos_notifications
    // Solo el destinatario o SA pueden leer.
    // ============================================================
    match /cronos_notifications/{notifId} {
      allow read: if isAuth() && (
        isSuperAdmin() ||
        request.auth.uid == resource.data.userId ||
        sameClubAsDoc(resource.data.clubId)
      );
      allow create: if isAuth();
      allow update: if isAuth() && (
        isSuperAdmin() ||
        request.auth.uid == resource.data.userId
      );
      allow delete: if isAuth() && (
        isSuperAdmin() ||
        request.auth.uid == resource.data.userId
      );
    }

    // ============================================================
    // COLECCIÓN: cronos_player_reports
    // Lectura permitida a:
    //   - SuperAdmin
    //   - Miembro del mismo club (sameClubAsDoc por claims de token)
    //   - El entrenador que generó el informe (coachUid — campo correcto)
    //   - El padre destinatario del informe individual (parentUid)
    //   - transitional (primeros 5 min post-registro)
    // FIX: antes comparaba resource.data.coachId (campo inexistente);
    //      el campo real guardado es resource.data.coachUid.
    // FIX 2: añadido parentUid para que padres lean sus informes.
    // ============================================================
    match /cronos_player_reports/{reportId} {
      allow read: if isAuth() && (
        isSuperAdmin() ||
        sameClubAsDoc(resource.data.clubId) ||
        (request.auth.token.get('clubId', null) != null &&
         request.auth.token.get('clubId', null) == resource.data.clubId) ||
        (request.auth.token.get('role', '') in ['director', 'coordinator', 'coach'] &&
         request.auth.token.get('clubId', null) == resource.data.clubId) ||
        request.auth.uid == resource.data.coachUid ||
        request.auth.uid == resource.data.parentUid ||
        transitionalRead(resource.data.clubId)
      );
      allow create: if isAuth();
      allow update: if isAuth() && (
        isSuperAdmin() ||
        sameClubAsDoc(resource.data.clubId) ||
        request.auth.uid == resource.data.coachUid
      );
      allow delete: if isAuth() && (
        isSuperAdmin() ||
        sameClubAsDoc(resource.data.clubId) ||
        request.auth.uid == resource.data.coachUid
      );
    }

    // ============================================================
    // COLECCIÓN: cronos_player_links (códigos invitación padres)
    //
    // Estructura del documento: { clubId, playerNumber, playerAlias,
    //   playerName, teamName, parentUid, parentEmail, parentWA,
    //   inviteCode, coachUid, coachEmail, linkedAt }
    // ID del documento: {clubId}_{playerNumber}
    //
    // FIX CRÍTICO: antes era "allow read, write: if isAuth()"
    // — cualquier usuario autenticado podía leer/escribir los
    // códigos de invitación de cualquier club.
    //
    // Ahora:
    //   read   → SA | miembro del mismo club | padre propietario |
    //            transitional (para el flujo de alta del padre con código)
    //   create → SA | miembro del mismo club (el entrenador crea el enlace)
    //   update → SA | miembro del mismo club | el padre que se vincula
    //            (auth.js actualiza parentUid/email al usar el inviteCode)
    //   delete → SA | miembro del mismo club
    // ============================================================
    match /cronos_player_links/{linkId} {
      allow read: if isAuth() && (
        isSuperAdmin() ||
        isLinkOwner() ||
        isLinkClubMember() ||
        transitionalRead(resource.data.clubId)
      );
      allow create: if isAuth() && (
        isSuperAdmin() ||
        sameClub(request.resource.data.clubId) ||
        sameClubAsDoc(request.resource.data.clubId)
      );
      allow update: if isAuth() && (
        isSuperAdmin() ||
        isLinkOwner() ||
        isLinkClubMember()
      );
      allow delete: if isAuth() && (
        isSuperAdmin() ||
        isLinkClubMember()
      );
    }

    // ============================================================
    // COLECCIÓN: deletion_requests
    // ============================================================
    match /deletion_requests/{reqId} {
      allow read: if isAuth() && (
        isSuperAdmin() ||
        request.auth.uid == resource.data.userId
      );
      allow create: if isAuth();
      allow update: if isSuperAdmin();
      allow delete: if isSuperAdmin();
    }

    // ============================================================
    // COLECCIÓN: live_matches (seguimiento en vivo — padres sin login)
    // Lectura pública necesaria para el portal live.html sin autenticación.
    // ============================================================
    match /live_matches/{matchId} {
      allow read: if true;
      allow create, update: if isAuth();
      allow delete: if isAuth();
    }

    // ============================================================
    // COLECCIÓN: users/{uid}/cronos_data
    // ============================================================
    match /users/{userId}/cronos_data/{docId} {
      allow read, write: if isAuth() && request.auth.uid == userId;
    }

    // ============================================================
    // COLECCIÓN: offline_events
    // ============================================================
    match /offline_events/{eventId} {
      allow read: if isAuth() && resource.data.userUid == request.auth.uid;
      allow create: if isAuth();
      allow update, delete: if isAuth() && resource.data.userUid == request.auth.uid;
    }

    // ============================================================
    // COLECCIÓN: config / cronos_config
    // ============================================================
    match /config/{configId} {
      allow read: if isAuth();
      allow write: if isSuperAdmin();
    }

    match /cronos_config/{configId} {
      allow read: if isAuth();
      allow write: if isSuperAdmin();
    }

    // ============================================================
    // COLECCIÓN: pseudonym_map
    // ============================================================
    match /pseudonym_map/{mapId} {
      allow read: if isAuth() && (
        isSuperAdmin() ||
        sameClub(resource.data.clubId) ||
        transitionalRead(resource.data.clubId)
      );
      allow write: if false;
    }

    // ============================================================
    // COLECCIÓN: audit_logs / error_logs
    // ============================================================
    match /audit_logs/{logId} {
      allow read: if isSuperAdmin();
      allow write: if false;
    }

    match /error_logs/{logId} {
      allow read: if isSuperAdmin();
      allow write: if false;
    }

    // ============================================================
    // COLECCIÓN: notifications
    // ============================================================
    match /notifications/{notifId} {
      allow read: if isAuth() && (
        isSuperAdmin() ||
        request.auth.uid == resource.data.userId ||
        sameClubAsDoc(resource.data.clubId)
      );
      allow create: if isAuth();
      allow update: if isAuth() && (
        isSuperAdmin() ||
        request.auth.uid == resource.data.userId
      );
      allow delete: if isSuperAdmin();
    }

    // ============================================================
    // COLECCIÓN: slot_requests
    // ============================================================
    match /slot_requests/{reqId} {
      allow read: if isAuth() && (
        isSuperAdmin() ||
        request.auth.uid == resource.data.userId ||
        sameClubAsDoc(resource.data.clubId)
      );
      allow create: if isAuth();
      allow update: if isAuth() && (
        isSuperAdmin() ||
        sameClubAsDoc(resource.data.clubId)
      );
      allow delete: if isSuperAdmin();
    }

    // ============================================================
    // COLECCIÓN: succession_requests
    // Admin de Club crea solicitud (solo si es el admin saliente).
    // SuperAdmin lee, aprueba/rechaza (update). Nadie más accede.
    // ============================================================
    match /succession_requests/{reqId} {
      allow read: if isSuperAdmin();
      allow create: if isAuth() &&
                       request.auth.token.role == 'club_admin' &&
                       request.resource.data.outgoingAdminUid == request.auth.uid;
      allow update: if isSuperAdmin();
      allow delete: if isSuperAdmin();
    }

    // ============================================================
    // COLECCIONES DE FACTURACIÓN
    // Solo SA puede gestionar planes y facturas.
    // Club admin e individual pueden leer sus propias facturas.
    // ============================================================
    match /billing_plans/{planId} {
      allow read: if isAuth();
      allow write: if isSuperAdmin();
    }

    match /billing_subscriptions/{subId} {
      allow read: if isSuperAdmin() ||
                     (isAuth() && resource.data.entityId == request.auth.token.clubId) ||
                     (isAuth() && resource.data.entityId == request.auth.uid);
      allow create: if isSuperAdmin();
      allow update: if isSuperAdmin();
      allow delete: if isSuperAdmin();
    }

    match /billing_invoices/{invId} {
      allow read: if isSuperAdmin() ||
                     (isAuth() && resource.data.entityId == request.auth.token.clubId) ||
                     (isAuth() && resource.data.entityId == request.auth.uid);
      allow create: if isSuperAdmin();
      allow update: if isSuperAdmin();
      allow delete: if isSuperAdmin();
    }

    // ============================================================
    // CATCH-ALL — bloquear TODO lo no definido explícitamente.
    //
    // FIX CRÍTICO: antes era "allow read: if isAuth()" — cualquier
    // colección nueva sin regla propia era legible por todos.
    // Ahora: denegado por defecto. Si se crea una colección nueva,
    // hay que añadir su regla explícitamente aquí arriba.
    // ============================================================
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
